# ── Backend ───────────────────────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb://localhost:27017/roadguard
AI_SERVICE_URL=http://localhost:8000
NODE_ENV=development

# ── AI Service ────────────────────────────────────────────────────────────
AI_HOST=0.0.0.0
AI_PORT=8000
# Path to your trained YOLOv8 weights (relative to ai-service/)
MODEL_PATH=model/best.pt

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api
# Get a free token at https://account.mapbox.com  (optional – Leaflet OSM is used by default)
VITE_MAPBOX_TOKEN=
